export EDITOR=nvim

#move configpath for lazygit/lazydocker to .config
export XDG_CONFIG_HOME="$HOME/.config"

# golang
export PATH="$HOME/go/bin:$PATH"

#asdf
export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
# append completions to fpath
fpath=(${ASDF_DATA_DIR:-$HOME/.asdf}/completions $fpath)
fpath=(~/.oh-my-zsh/completions $fpath)

# initialise completions with ZSH's compinit (cached, rebuilds once per day)
autoload -Uz compinit
if [ $(date +'%j') != $(stat -f '%Sm' -t '%j' ~/.zcompdump 2>/dev/null) ]; then
    compinit
else
    compinit -C
fi

### EXPORT INSTALLED PROGRAMS
export PATH="/opt/homebrew/bin:$PATH"
export PATH="/opt/homebrew/sbin:$PATH"
# Я ваще хз что это, но установил т.к через asdf не устанавливался php
# На макос он установлен в /usr/bin/bison 2.3
export PATH="/opt/homebrew/opt/bison/bin:$PATH"
# Add Go to PATH
export PATH="/opt/homebrew/opt/go/bin:$PATH"

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load
ZSH_THEME="bureau"

# Auto-update every 7 days
zstyle ':omz:update' frequency 7

# Enable command auto-correction
ENABLE_CORRECTION="false"

# Which plugins would you like to load?
plugins=(
    git
    docker
    docker-compose
    macos
    composer
    kubectl
    history
    zsh-autosuggestions
    dotenv
    gpg-agent
    keychain
    # zsh-vi-mode
)

source $ZSH/oh-my-zsh.sh

# User configuration

### > alias section ###

# Open ObsidianNotes with NeoVim
alias nvnotes='cd ~/Library/Mobile\ Documents/iCloud~md~obsidian/Documents/ObsidianNotes; nvim'
alias mux=tmuxinator
alias cat=bat

### < alias section ###

# Added by Docker Desktop
source "$HOME/.docker/init-zsh.sh" || true

# Enable ngrok completion if installed
if command -v ngrok &>/dev/null; then
    eval "$(ngrok completion)"
fi

# Added with JetBrains crack-script
___my_vmoptions_shell_file="${HOME}/.jetbrains.vmoptions.sh"
if [ -f "${___my_vmoptions_shell_file}" ]; then . "${___my_vmoptions_shell_file}"; fi

# Set up fzf key bindings and fuzzy completion
source <(fzf --zsh)
export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --glob "!.git"'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'
# Set up fuck (lazy-loaded to avoid startup delay)
fuck() { eval $(thefuck $(fc -ln -1)); }

# Syntax highlighting — must be last
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
